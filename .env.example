# Public site URL for canonical tags, sitemap, and structured data (always use www)
NEXT_PUBLIC_SITE_URL=https://www.screamingeaglecurbing.com

# Cloudflare Turnstile (Contact form)
# Dashboard → Turnstile → your widget → Hostname Management — add BOTH:
#   screamingeaglecurbing.com
#   www.screamingeaglecurbing.com
# Set the same keys in Vercel → Project → Settings → Environment Variables (Production).
# After deploy: purge Vercel cache / redeploy so apex→www redirect and env vars apply.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAACmutPDloFLjJ8s_
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
