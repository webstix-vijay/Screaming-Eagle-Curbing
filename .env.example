# Public site URL for canonical tags, sitemap, and structured data
NEXT_PUBLIC_SITE_URL=https://www.screamingeaglecurbing.com

# Cloudflare Turnstile (Contact form)
# In the Cloudflare dashboard → Turnstile → your widget → Hostname Management, add:
#   screamingeaglecurbing.com
#   www.screamingeaglecurbing.com
# (Error 110200 means the current hostname is not on that list.)
# Set the same values in your hosting provider (e.g. Vercel) for production builds.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAACmutPDloFLjJ8s_
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
